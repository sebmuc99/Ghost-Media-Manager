#  Required 
# Your Ghost instance URL (no trailing slash)
GHOST_URL=https://your-ghost.com

# Ghost Admin API key
# Get from: Ghost Admin  Settings  Integrations  Add custom integration
GHOST_ADMIN_API_KEY=your-id:your-secret

#  Filesystem Access (optional but recommended) 
# Mount Ghost content directories to enable:
# rename, delete, image editor, usage badges
#
# Example Docker volume setup:
#   volumes:
#     - /path/to/ghost/content/images:/ghost-images
#     - /path/to/ghost/content/media:/ghost-media
#     - /path/to/ghost/content/files:/ghost-files

GHOST_MEDIA_PATH=/ghost-images
GHOST_MEDIA_VIDEO_PATH=/ghost-media
GHOST_MEDIA_FILES_PATH=/ghost-files

#  AI Features (optional) 
# Get API key from: https://console.anthropic.com
# Estimated costs: ~$0.06 for 50 excerpts, ~$0.05 per image post

# ANTHROPIC_API_KEY=sk-ant-...
# AI_MODEL_TEXT=claude-haiku-4-5-20251001
# AI_MODEL_VISION=claude-opus-4-6
# AI_MODEL_CONTENT=claude-sonnet-4-6   # long-form content generation (falls back to AI_MODEL_TEXT)

#  Immich Integration (optional) 
# IMMICH_URL=https://your-immich.com
# IMMICH_API_KEY=your-immich-api-key

#  Server 
PORT=3334
# NODE_ENV=production
